# ===== Backend Environment =====
NODE_ENV=development
PORT=5000

# ===== Database =====
MONGODB_URI=mongodb://root:root@mongo:27017/ai-chat-site?authSource=admin
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root

# ===== JWT Configuration =====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRE=30d

# ===== AI API Keys =====
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229

# ===== File Upload =====
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,txt,md,json,csv
UPLOAD_DIR=./uploads

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
CHAT_RATE_LIMIT_MAX=50
CHAT_RATE_LIMIT_WINDOW=3600

# ===== Admin Configuration =====
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ===== Logging =====
LOG_LEVEL=info
LOG_DIR=./logs

# ===== Frontend Environment =====
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_APP_NAME=AI Chat Site
VITE_APP_VERSION=1.0.0
